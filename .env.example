# At least one API key is required. OpenAI is used by default.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional: force a specific provider ("openai" or "gemini").
# If unset, auto-detects based on which API key is present (prefers OpenAI).
LLM_PROVIDER=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
